{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MaksIT.CertsUI.Engine.Persistance": "Debug"
    }
  },
  "AllowedHosts": "*",

  "Configuration": {
    "CertsUIEngineConfiguration": {
      "ConnectionString": "",
      "AutoSyncSchema": false,

      "Admin": {
        "Username": "",
        "Password": ""
      },

      "JwtSettingsConfiguration": {
        "JwtSecret": "",
        "Issuer": "",
        "Audience": "",
        "ExpiresIn": 30,
        "RefreshTokenExpiresIn": 7,
        "PasswordPepper": ""
      },

      "TwoFactorSettingsConfiguration": {
        "Label": "",
        "Issuer": "",
        "Algorithm": "",
        "Digits": 6,
        "Period": 30,
        "TimeTolerance": 1
      },

      "Agent": {
        "AgentHostname": "",
        "AgentPort": 9000,
        "AgentKey": "",
        "ServiceToReload": "haproxy"
      },

      "Production": "https://acme-v02.api.letsencrypt.org/directory",
      "Staging": "https://acme-staging-v02.api.letsencrypt.org/directory",
      "AcmeFolder": "/acme",
      "DataFolder": "/data"
    }
  }
}
